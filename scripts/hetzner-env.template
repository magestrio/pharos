# Hetzner production .env template for the Vault8004 agent compose stack.
#
# Workflow:
#   1. Copy this file locally: cp scripts/hetzner-env.template /tmp/vault8004.env
#   2. Fill in EVERY <REPLACE_…> placeholder below.
#   3. scp it to the box: scp /tmp/vault8004.env root@<box-ip>:/root/vault8004/.env
#   4. scp the Bybit RSA PEM separately: scp ~/.config/vault8004/bybit-sandbox-rsa.pem
#        root@<box-ip>:/etc/vault8004/bybit-rsa.pem
#   5. Run the bootstrap: ssh root@<box-ip> 'bash /opt/vault8004/scripts/hetzner-bootstrap.sh'
#
# Generate POSTGRES_PASSWORD with:   openssl rand -hex 24
#
# This file omits every on-chain credential (PRIVATE_KEY, SAFE_SIGNER_*_KEY,
# AGENT_PRIVATE_KEY, etc.) because the off-chain agent loop on Hetzner does
# not need them. Keep them off the prod box for blast-radius reasons.

# --- Compose / infra ---
POSTGRES_PASSWORD=<REPLACE_WITH_openssl_rand_hex_24>
AGENT_API_DOMAIN=<REPLACE_e.g._api.vault8004.xyz>
CADDY_EMAIL=<REPLACE_lets_encrypt_contact_email>
BYBIT_RSA_HOST_PATH=/etc/vault8004/bybit-rsa.pem

# --- Mantle (read-only snapshot context for .37a Aave leg) ---
MANTLE_RPC_URL=https://rpc.mantle.xyz
# SAFE address: 0x4dc4a70Ae02d7ca2F3A06b1231b3A9312d82a037 (vault8004 mainnet)
MANTLE_VAULT_ADDRESS=0x4dc4a70Ae02d7ca2F3A06b1231b3A9312d82a037

# --- Bybit (off-chain yield ops) ---
# Public API key string from Bybit (RSA auth).
BYBIT_API_KEY=<REPLACE_bybit_api_key>
# In-container PEM path — pinned by compose.yml to /run/secrets/bybit-rsa.pem.
# Don't change unless you also change the mount in compose.yml.
BYBIT_PRIVATE_KEY_PATH=/run/secrets/bybit-rsa.pem

# --- Anthropic (LLM decision step) ---
ANTHROPIC_API_KEY=<REPLACE_sk_ant_…>

# --- Optional services ---
# Pinata: only needed if the agent pins rationale to IPFS each cycle.
PINATA_JWT=<REPLACE_or_leave_blank>
# Allora: only needed if the agent fetches live inferences.
ALLORA_API_KEY=<REPLACE_or_leave_blank>
