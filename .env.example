MANTLE_RPC_URL=
MANTLE_SEPOLIA_RPC_URL=
# SAFE vault address — sandbox snapshot reads USDC + aUSDC balance here
# for the .37a Aave V3 on-chain context. Empty = on-chain leg disabled.
MANTLE_VAULT_ADDRESS=
PRIVATE_KEY=
ANTHROPIC_API_KEY=
PINATA_JWT=
ALLORA_API_KEY=
ETHERSCAN_API_KEY=

# --- Agent loop (Execute phase) ---
# CapitalManager — the contract the agent calls executeAllocation on.
CAPITAL_MANAGER_ADDRESS=
# Whitelisted strategy adapters consumed by the AllocationCall builder.
# Address 0x0 disables the venue (builder treats current balance as 0).
AAVE_V3_USDC_ADAPTER=
# NOTE: aave_v3_weth target > 0 fail-closes in build_allocation_calls
# until a USDC<->WETH swap rail lands (see weth-funding-gap TODO).
AAVE_V3_WETH_ADAPTER=
BYBIT_ATTESTOR_ADAPTER=
# Agent EOA private key — must match CapitalManager.agent().
AGENT_PRIVATE_KEY=

# --- Deploy.s.sol inputs ---
# Deployer EOA (derived from PRIVATE_KEY). Must hold MNT for gas + USDC for bootstrap.
DEPLOYER_ADDRESS=
# Gnosis Safe (2-of-3) — receives ownership of Vault8004 + DecisionLog. Mainnet: 0x4dc4a70Ae02d7ca2F3A06b1231b3A9312d82a037
SAFE_OWNER=
# ERC-8004 Reputation Registry on Mantle (canonical). Mainnet: 0x8004BAa17C55a88189AE136b182e5fdA19dE9b63
REGISTRY_8004=
# AI agent EOA — calls allocate/deallocate post-deploy. MUST be set for mainnet; fallback is DEPLOYER_ADDRESS.
AGENT_ADDRESS=
# tokenId from IdentityRegistry.register() — set after AI agent identity NFT minted.
AGENT_ID=
# Safe (2-of-3) that controls the Bybit account and confirms BybitAttestor deposits/withdraws.
# For mainnet this MUST equal SAFE_OWNER. Deploy.s.sol falls back to DEPLOYER_ADDRESS for dev only.
ATTESTOR_ADDRESS=
# Phase B input: address of the deployed vUSDC token. When set, Deploy.s.sol will call
# CapitalManager.setVusdc(...) and transfer ownership to SAFE_OWNER in a single broadcast.
# Leave empty for Phase A (cold start).
VUSDC_ADDR=
# Optional: Chainlink L2 Sequencer Uptime Feed on Mantle. address(0) disables the check.
# Pending research — keep empty until feed address is verified. See notes/addresses.md.
SEQUENCER_FEED=
# For `forge script --verify` against Mantle Explorer
MANTLESCAN_API_KEY=

# --- Safe ops (packages/safe-ops) ---
# Gnosis Safe (2-of-3) — same as SAFE_OWNER above. Mainnet: 0x4dc4a70Ae02d7ca2F3A06b1231b3A9312d82a037
SAFE_ADDRESS=
# Private keys for two operational signers. Both kept locally collapses 2/3 to 1/1
# from a compromise standpoint — acceptable for hackathon ops velocity only.
# Signer C (cold backup) must NEVER be put here.
SAFE_SIGNER_A_KEY=
SAFE_SIGNER_B_KEY=

# --- Hetzner deploy (compose.yml) ---
# Postgres password — used in both DATABASE_URL (built by compose) and the
# postgres container's POSTGRES_PASSWORD. Generate with `openssl rand -hex 24`.
POSTGRES_PASSWORD=
# Public domain pointed at the Hetzner box (A record). Caddy issues a TLS
# cert for it on first start. Web frontend hits https://<this>/cycles etc.
AGENT_API_DOMAIN=
# Contact email for Let's Encrypt cert issuance + expiry warnings.
CADDY_EMAIL=
# --- Bybit (oracle + execute) ---
# Read+trade keys for the SAFE-controlled Bybit account. Bybit settings checked
# at boot via permission_probe — bad keys fail-fast, not at first trade.
BYBIT_API_KEY=
BYBIT_API_SECRET=
