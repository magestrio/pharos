# Vault8004 — canonical env schema (single naming style).
#
# Naming rules:
#   - contract addresses        → <NAME>_ADDRESS
#   - the operational EOA key    → PRIVATE_KEY  (deployer == agent)
#   - block-explorer key         → MANTLESCAN_API_KEY
#   - the Gnosis Safe            → SAFE_ADDRESS
#   - feature flags              → VAULT8004_*
#   - web (Next.js, client-side) → NEXT_PUBLIC_<same base name>
#
# Local dev (`pnpm start`) auto-generates .env.local from the anvil-fork
# deploy; this file documents the schema and seeds a real .env.

# --- Network ---
MANTLE_RPC_URL=https://rpc.mantle.xyz
MANTLE_SEPOLIA_RPC_URL=https://rpc.sepolia.mantle.xyz
MANTLE_CHAIN_ID=5000

# --- Operational EOA (single key: deployer == agent) ---
# Signs Deploy.s.sol broadcasts AND DecisionLog.recordDecision /
# ReputationOracle.updateReputation / CapitalManager.allocate. Its address
# MUST equal DecisionLog.agent() + CapitalManager.agent() (set via setAgent),
# else the on-chain writer self-disables. DEPLOYER_ADDRESS is derived from it.
PRIVATE_KEY=

# --- Deployed contracts (Mantle mainnet) ---
CAPITAL_MANAGER_ADDRESS=
VUSDC_ADDRESS=
DECISION_LOG_ADDRESS=
REPUTATION_ORACLE_ADDRESS=
AAVE_V3_USDC_ADAPTER_ADDRESS=
AAVE_V3_WETH_ADAPTER_ADDRESS=
BYBIT_ATTESTOR_ADDRESS=
# USDC token on Mantle (orchestrator bridges escrow-released USDC).
USDC_ADDRESS=0x09Bc4E0D864854c6aFB6eB9A9cdF58aC190D0dF9
# SAFE vault address — snapshot reads its USDC + aUSDC balance (.37a Aave leg).
MANTLE_VAULT_ADDRESS=

# --- Identity / ownership ---
# AI agent EOA — equals PRIVATE_KEY's address under the single-key model.
AGENT_ADDRESS=
# tokenId from IdentityRegistry.register().
AGENT_ID=
# Deployer EOA — derived from PRIVATE_KEY; must hold MNT for gas + USDC for bootstrap.
DEPLOYER_ADDRESS=
# Gnosis Safe (2-of-3) — owns CapitalManager + DecisionLog. Mainnet: 0x4dc4a70Ae02d7ca2F3A06b1231b3A9312d82a037
SAFE_ADDRESS=
# Safe (2-of-3) controlling the Bybit account for BybitAttestor confirms. Mainnet == SAFE_ADDRESS.
ATTESTOR_ADDRESS=
# Canonical ERC-8004 Reputation Registry on Mantle: 0x8004BAa17C55a88189AE136b182e5fdA19dE9b63
REGISTRY_8004=
# Optional Chainlink L2 Sequencer Uptime Feed. address(0) disables the check.
SEQUENCER_FEED=
# Mantle Explorer key for `forge script --verify`.
MANTLESCAN_API_KEY=

# --- Safe ops (packages/safe-ops) ---
# Two operational signers. Signer C (cold backup) must NEVER be put here.
SAFE_SIGNER_A_KEY=
SAFE_SIGNER_B_KEY=

# --- Bybit attestor on-chain signer (deferred; off-chain sleeve) ---
# Pushes BybitAttestor.confirmDeposit / confirmWithdraw / updateBalance.
ATTESTOR_PRIVATE_KEY=

# --- LLM + data ---
ANTHROPIC_API_KEY=
ALLORA_API_KEY=
PINATA_JWT=

# --- Bybit (oracle + execute) ---
# V5 RSA auth (sign-type=1): BYBIT_API_KEY + the RSA PEM whose public half
# is registered with the key. Default PEM: ~/.config/vault8004/bybit-sandbox-rsa.pem.
BYBIT_API_KEY=
BYBIT_PRIVATE_KEY_PATH=

# --- Database (cycle store) ---
DATABASE_URL=

# --- Agent feature flags ---
VAULT8004_ALPHA_SLIPPAGE=0.01
VAULT8004_ALPHA_EXEC_ENABLED=0
VAULT8004_DAILY_DRAWDOWN_HALT_PCT=

# --- Hetzner deploy (compose.yml + scripts/vault.sh remote) ---
POSTGRES_PASSWORD=
AGENT_API_DOMAIN=
CADDY_EMAIL=
# Host-side absolute path to the Bybit RSA PEM, mounted into the agent container.
BYBIT_RSA_HOST_PATH=/etc/vault8004/bybit-rsa.pem
HETZNER_HOST=
HETZNER_USER=root
HETZNER_REPO_DIR=/opt/vault8004
# SSH key authorized on the box (deploy). Default: ~/.ssh/hetzner_ed25519.
HETZNER_SSH_KEY=

# --- Web (Next.js client; set in Vercel for prod). Same base names + NEXT_PUBLIC_ ---
NEXT_PUBLIC_RPC_URL=
NEXT_PUBLIC_CHAIN_ID=
NEXT_PUBLIC_AGENT_ID=
NEXT_PUBLIC_CAPITAL_MANAGER_ADDRESS=
NEXT_PUBLIC_VUSDC_ADDRESS=
NEXT_PUBLIC_DECISION_LOG_ADDRESS=
NEXT_PUBLIC_REPUTATION_ORACLE_ADDRESS=
NEXT_PUBLIC_AAVE_USDC_ADAPTER_ADDRESS=
NEXT_PUBLIC_AAVE_WETH_ADAPTER_ADDRESS=
NEXT_PUBLIC_BYBIT_ATTESTOR_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS=
NEXT_PUBLIC_WC_PROJECT_ID=
