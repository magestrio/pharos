{
  "name": "vault8004",
  "private": true,
  "scripts": {
    "build:contracts": "cd contracts && forge build && node scripts/export-abi.js",
    "dev:web": "pnpm --filter web dev",
    "dev:agent": "bash scripts/vault.sh agent:loop",
    "fetch-data": "uv run --directory agent python -m agent.data.cli",
    "safe:tx": "pnpm --filter @vault8004/safe-ops run tx",
    "safe:set-uri": "pnpm --filter @vault8004/safe-ops run set-agent-uri",
    "safe:register": "pnpm --filter @vault8004/safe-ops run register-agent",
    "start": "bash scripts/vault.sh start",
    "sync": "bash scripts/vault.sh sync",
    "deploy": "bash scripts/vault.sh deploy",
    "stop": "bash scripts/vault.sh stop",
    "restart": "bash scripts/vault.sh restart",
    "status": "bash scripts/vault.sh status",
    "logs": "bash scripts/vault.sh logs",
    "agent:run": "bash scripts/vault.sh agent:run",
    "agent:loop": "bash scripts/vault.sh agent:loop",
    "db:reset": "bash scripts/vault.sh db:reset",
    "contracts:deploy": "bash scripts/vault.sh contracts:deploy"
  }
}
